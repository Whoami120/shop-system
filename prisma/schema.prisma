generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
}

model Shop {
  id            String   @id @default(cuid())
  name          String
  imageUrl      String?
  address       String?
  phone         String?
  receiptFooter String?
  createdAt     DateTime @default(now())

  users       User[]
  products    Product[]
  stockMoves  StockMove[]
  suppliers   Supplier[]
  receptions  Reception[]
  shopModules ShopModule[]
  sales       Sale[]
}

enum Role {
  SUPERADMIN
  ADMIN
  CASHIER
  STOCK
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  email     String?  @unique
  password  String
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  stockMoves StockMove[]
  sales      Sale[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float    @default(0)
  quantity  Int      @default(0)
  imageUrl  String?
  tva       Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  stockMoves     StockMove[]
  receptionItems ReceptionItem[]
  saleItems      SaleItem[]
}

enum MoveType {
  RECEPTION
  SALE
  BROKEN
}

model StockMove {
  id        String   @id @default(cuid())
  type      MoveType
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
  productId String

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  city      String?
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  receptions Reception[]
}

model Reception {
  id        String   @id @default(cuid())
  total     Float    @default(0)
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?

  items ReceptionItem[]
}

model ReceptionItem {
  id            String @id @default(cuid())
  quantity      Int
  purchasePrice Float  @default(0)

  reception   Reception @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  receptionId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model Module {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  shopModules ShopModule[]
}

model ShopModule {
  id       String @id @default(cuid())
  enabled  Boolean @default(true)

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String

  @@unique([shopId, moduleId])
}

model Sale {
  id        String   @id @default(cuid())
  total     Float    @default(0)
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  items SaleItem[]
}

model SaleItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float  @default(0)

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}
// ---------- AUDIT LOG (who did what) ----------
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())

  shopId   String
  userId   String
  userName String
}