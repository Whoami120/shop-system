// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
}
// ---------- SHOP (each business is one tenant) ----------
model Shop {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users       User[]
  products    Product[]
  stockMoves  StockMove[]
  suppliers   Supplier[]
  receptions  Reception[]
  shopModules ShopModule[]
}
// ---------- USERS (with roles) ----------
enum Role {
  ADMIN
  CASHIER
  STOCK
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  email     String?  @unique
  password  String
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  stockMoves StockMove[]
}

// ---------- PRODUCTS ----------
model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float    @default(0)
  quantity  Int      @default(0)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  stockMoves     StockMove[]
  receptionItems ReceptionItem[]
}

// ---------- STOCK MOVES (every change in stock) ----------
enum MoveType {
  RECEPTION
  SALE
  BROKEN
}

model StockMove {
  id        String   @id @default(cuid())
  type      MoveType
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
  productId String

  shop      Shop     @relation(fields: [shopId], references: [id])
  shopId    String

  user      User     @relation(fields: [userId], references: [id])
  userId    String
}
// ---------- SUPPLIER (fournisseur) ----------
model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  receptions Reception[]
}

// ---------- RECEPTION (the document / bon de réception) ----------
model Reception {
  id        String   @id @default(cuid())
  total     Float    @default(0)
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?

  items ReceptionItem[]
}

// ---------- RECEPTION ITEM (one line in a reception) ----------
model ReceptionItem {
  id            String @id @default(cuid())
  quantity      Int
  purchasePrice Float  @default(0)

  reception   Reception @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  receptionId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}
// ---------- MODULE (the catalog of all modules) ----------
model Module {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  shopModules ShopModule[]
}

// ---------- SHOP MODULE (which shop has which module) ----------
model ShopModule {
  id       String @id @default(cuid())
  enabled  Boolean @default(true)

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String

  // a shop can have each module only once
  @@unique([shopId, moduleId])
}